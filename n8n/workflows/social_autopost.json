{
  "name": "XangVang Social Autopost",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        180,
        260
      ]
    },
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "custom",
              "cronExpression": "* * * * *"
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Schedule TEST Every Minute",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        180,
        120
      ]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "={{($env.SITE_API_BASE_URL || 'https://xangvang24h.vn/api') + '/social/render-payload'}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"platform\": \"general\",\n  \"template\": \"daily-card\",\n  \"utm_source\": \"social\",\n  \"utm_medium\": \"auto\",\n  \"utm_campaign\": \"daily-update\"\n}",
        "responseFormat": "json"
      },
      "id": "http-gold-today",
      "name": "Get Social Render Payload",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        420,
        190
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $json || {};\nconst summary = response.summary || {};\nconst render = response.render_payload || {};\n\nconst date = summary.date || new Date().toISOString().slice(0, 10);\nconst payload = summary.metrics || {};\nconst dedupeKey = [\n  date,\n  payload.gold_sjc_sell ?? '',\n  payload.gold_world_sell ?? '',\n  payload.fuel_ron95_vung1 ?? ''\n].join('|');\n\nreturn [{\n  json: {\n    date,\n    link: render?.cta?.url || summary.links?.home || '',\n    facebookMessage: summary.captions?.facebook || render.caption || '',\n    tiktokCaption: summary.captions?.tiktok || render.caption || '',\n    payload,\n    title: render.title || summary.title_variants?.[0] || '',\n    hashtags: summary.hashtags || {},\n    dedupeKey\n  }\n}];"
      },
      "id": "build-social-content",
      "name": "Build Social Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        190
      ]
    },
    {
      "parameters": {
        "jsCode": "const allowDuplicate = String($env.ALLOW_DUPLICATE_POST || 'false').toLowerCase() === 'true';\nif (allowDuplicate) {\n  return [{ json: $json }];\n}\n\nconst item = $json || {};\nconst today = item.date || new Date().toISOString().slice(0, 10);\nconst key = item.dedupeKey || `${today}|${item.facebookMessage || ''}|${item.tiktokCaption || ''}`;\n\nconst state = this.getWorkflowStaticData('global');\nif (state.lastDate === today && state.lastKey === key) {\n  return [];\n}\n\nstate.lastDate = today;\nstate.lastKey = key;\nstate.lastRunAt = new Date().toISOString();\n\nreturn [{ json: item }];"
      },
      "id": "idempotency-guard",
      "name": "Idempotency Guard (Daily)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        930,
        190
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ !!$env.FB_PAGE_ID && !!$env.FB_PAGE_ACCESS_TOKEN }}",
              "operation": "isTrue"
            }
          ]
        }
      },
      "id": "if-facebook-enabled",
      "name": "Facebook Enabled?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1160,
        120
      ]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "=https://graph.facebook.com/v20.0/{{$env.FB_PAGE_ID}}/feed",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "message",
              "value": "={{$json.facebookMessage}}"
            },
            {
              "name": "link",
              "value": "={{$json.link}}"
            },
            {
              "name": "access_token",
              "value": "={{$env.FB_PAGE_ACCESS_TOKEN}}"
            }
          ]
        }
      },
      "id": "post-facebook",
      "name": "Post Facebook Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1410,
        70
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ !!$env.TIKTOK_WEBHOOK_URL }}",
              "operation": "isTrue"
            }
          ]
        }
      },
      "id": "if-tiktok-enabled",
      "name": "TikTok Webhook Enabled?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1160,
        280
      ]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "={{$env.TIKTOK_WEBHOOK_URL}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"caption\": $json.tiktokCaption,\n  \"link\": $json.link,\n  \"date\": $json.date,\n  \"payload\": $json.payload\n}"
      },
      "id": "send-tiktok-webhook",
      "name": "Send TikTok Payload",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1410,
        300
      ]
    }
  ],
